generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String
  role              String    @default("owner")
  plan              String    @default("free")
  subscriptionEndsAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projects  Project[]
  providers AiProvider[]
  tasks     Task[]
  commands  Command[]
  memories  AiMemory[]
  logs      Log[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  status      String   @default("active")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  tasks    Task[]
  commands Command[]
  memories AiMemory[]
}

model AiProvider {
  id        String   @id @default(cuid())
  name      String
  apiKey    String
  baseUrl   String?
  isActive  Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, name])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  type      String
  status    String   @default("pending")
  progress  Int      @default(0)
  plan      String?
  result    String?
  error     String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  command Command?
  logs    Log[]
}

model Command {
  id        String   @id @default(cuid())
  input     String
  analysis  String?
  type      String
  status    String   @default("received")
  projectId String?
  userId    String
  taskId    String?  @unique
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  meta      String?
  taskId    String?
  userId    String?
  createdAt DateTime @default(now())

  task Task? @relation(fields: [taskId], references: [id])
  user User? @relation(fields: [userId], references: [id])
}

model AiMemory {
  id        String   @id @default(cuid())
  key       String
  content   String
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@unique([userId, projectId, key])
}
